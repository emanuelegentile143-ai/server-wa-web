# --- Supabase Edge Function endpoints ---
SUPABASE_FUNCTIONS_URL=https://vxoyeupdgzhnrircuzjl.supabase.co/functions/v1

# Shared secret — must match WA_WEB_INGEST_KEY in Supabase secrets
WA_WEB_INGEST_KEY=replace_me_with_supabase_secret

# Comma-separated list of instances to spin up.
# Each item: <instance_id>:<sede>
# Example for two venues:
INSTANCES=montenero-main:montenero,termoli-main:termoli

# Polling interval (ms) for outbound queue per instance
POLL_INTERVAL_MS=4000

# HTTP port for status / QR dashboard (Railway sets PORT automatically)
PORT=3000

# Optional: protect /qr and /status endpoints with a basic token
ADMIN_TOKEN=change_me_admin_token

# Where to persist WA Web session data (Railway: mount a volume on this path)
SESSION_DIR=./.wwebjs_auth
